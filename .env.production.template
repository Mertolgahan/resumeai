# ResumeAI Production Environment Variables
# Copy this file to .env.production and fill in your actual values.
# NEVER commit this file to git — it is already in .gitignore

# --- Supabase ---
# Create project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---
# Generate key at https://platform.openai.com/api-keys
OPENROUTER_API_KEY=

# --- Stripe ---
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Create products in Stripe Dashboard, then copy price IDs:
#   Pro Monthly: $9/month recurring
#   Lifetime: $29 one-time
STRIPE_PRO_PRICE_ID=
STRIPE_LIFETIME_PRICE_ID=

# Set up webhook at https://dashboard.stripe.com/webhooks
# Endpoint: https://<your-domain>/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# --- App URL ---
# After Vercel deployment: https://your-app.vercel.app (or custom domain)
NEXT_PUBLIC_APP_URL=https://resumeai.vercel.app